# offlickr — local environment overrides
#
# Copy this file to .env and fill in real values. .env is gitignored.
# Request a Flickr API key (free, for non-commercial use) at:
#   https://www.flickr.com/services/apps/create/apply/
#
# Only needed if you use `offlickr fetch-external` or pass
# `--archive-external {avatars,thumbnails,full}`. The base build
# (`offlickr build ... --archive-external none`, the default) needs
# nothing in here.

FLICKR_API_KEY=your-api-key-here
FLICKR_API_SECRET=your-api-secret-here
