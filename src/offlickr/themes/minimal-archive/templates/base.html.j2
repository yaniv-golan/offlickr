{# base.html.j2 — inherited by all pages #}
{% from "_macros/flickr_attribution.html.j2" import head_meta, nav_handle %}
{% from "_macros/about_page.html.j2" import about_nav_link %}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="referrer" content="no-referrer">
  {{ head_meta(canonical_url) }}
  <title>{% block title %}{{ account.screen_name }}'s Photos{% endblock %}</title>
  <link rel="stylesheet" href="{{ base_url }}assets/style.css">
</head>
<body>
  <header class="site-header">
    <nav class="site-nav">
      <span class="nav-brand">
        <a href="{{ base_url }}index.html" class="nav-brand-name">
          {%- if account.real_name -%}{{ account.real_name | e }}{%- else -%}{{ account.screen_name | e }}{%- endif -%}
        </a>
        {{- nav_handle(account) }}
      </span>
      <ul class="nav-links">
        <li><a href="{{ base_url }}index.html"{% if active == 'photos' %} aria-current="page"{% endif %}>Photos</a></li>
        <li><a href="{{ base_url }}albums/index.html"{% if active == 'albums' %} aria-current="page"{% endif %}>Albums</a></li>
        <li><a href="{{ base_url }}tags/index.html"{% if active == 'tags' %} aria-current="page"{% endif %}>Tags</a></li>
        {% if has_map %}<li><a href="{{ base_url }}map.html"{% if active == 'map' %} aria-current="page"{% endif %}>Map</a></li>{% endif %}
        <li><a href="{{ base_url }}faves/index.html"{% if active == 'faves' %} aria-current="page"{% endif %}>Faves</a></li>
        <li><a href="{{ base_url }}groups/index.html"{% if active == 'groups' %} aria-current="page"{% endif %}>Groups</a></li>
        {{ about_nav_link(active, base_url) }}
      </ul>
      <div class="search-wrap">
        <input type="search" id="search-input" placeholder="Search…" autocomplete="off" aria-label="Search photos">
        <ul id="search-results" hidden role="listbox"></ul>
      </div>
      {% if scope_has_unsafe %}
      <button id="safety-toggle" class="safety-toggle-btn" type="button" aria-pressed="false">Safe only</button>
      {% endif %}
    </nav>
    {%- if scope_total_photos %}
    <div class="site-meta" aria-label="Archive scope">
      <span>{{ scope_total_photos | format_number }} photos</span>
      {%- if scope_year_from and scope_year_to %}
      <span class="site-meta-sep" aria-hidden="true">·</span>
      <span>{{ scope_year_from }}{% if scope_year_to != scope_year_from %}–{{ scope_year_to }}{% endif %}</span>
      {%- endif %}
      <span class="site-meta-sep" aria-hidden="true">·</span>
      <span>archived {{ scope_generated }}</span>
    </div>
    {%- endif %}
  </header>
  {% block photo_hero %}{% endblock %}
  {%- set _mc %}{% block main_class %}{% endblock %}{%- endset %}
  <main{% if _mc %} class="{{ _mc }}"{% endif %}>{% block content %}{% endblock %}</main>
  <footer class="site-footer">
    <small>Generated by <a href="https://github.com/yaniv-golan/offlickr" rel="noopener noreferrer external">offlickr</a></small>
  </footer>
  <script>var OFFLICKR_BASE="{{ base_url }}";var OFFLICKR_INDEX={{ search_index | tojson }};</script>
  <script src="{{ base_url }}assets/search.js"></script>
  {% if scope_has_unsafe %}
  <script src="{{ base_url }}assets/safety.js"></script>
  {% endif %}
</body>
</html>
